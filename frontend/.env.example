# Frontend environment variables (Vite)
#
# Vite auto-loads files by mode:
#   - `vite dev`   → .env + .env.development
#   - `vite build` → .env + .env.production   (release build)
# A VITE_* var passed in the shell takes precedence over .env files
# (the Makefile dev targets rely on this).
#
# Usage:
#   cp .env.example .env                  # local development defaults
#   cp .env.example .env.production       # then edit with the production HTTPS URL

# Backend API base URL.
#  - empty   → relative paths; `vite dev` proxy forwards to the backend (web dev, no CORS).
#  - set     → direct requests to that host (Capacitor app / release build).
# Leave empty for local dev. In production (.env.production) set an HTTPS domain.
#   e.g. .env.production →  VITE_API_BASE_URL=https://api.voro.example.com
VITE_API_BASE_URL=
