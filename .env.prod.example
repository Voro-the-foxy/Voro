# PostgreSQL password (choose a strong password)
POSTGRES_PASSWORD=change_me_strong_password

# Claude API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key — https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# Frontend origin for CORS (your server's public IP or domain)
# e.g. http://123.456.789.0  or  https://yourdomain.com
ALLOWED_ORIGIN=http://YOUR_SERVER_IP
