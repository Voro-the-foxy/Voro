# Production — copy to .env.prod and fill in real values
# Used by: make deploy  (runs docker-compose.prod.yml)
# Never commit .env.prod

# Strong Postgres password (shared by backend + ai-server containers)
POSTGRES_PASSWORD=change_me_strong_password

# Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI API key — https://dash.voyageai.com
VOYAGE_AI_KEY=pa-...

# Frontend origin for CORS (your server's public IP or domain)
# e.g. https://yourdomain.com
ALLOWED_ORIGIN=https://yourdomain.com
